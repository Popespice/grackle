{
  "name": "grackle-monorepo",
  "private": true,
  "packageManager": "pnpm@11.1.1",
  "scripts": {
    "dev": "concurrently -k -n agent,frontend -c cyan,magenta \"cd packages/agent && uv run grackle serve\" \"pnpm --filter @grackle/frontend dev\"",
    "build": "pnpm -r build",
    "lint": "biome ci .",
    "format": "biome check --write .",
    "pretypecheck": "pnpm codegen",
    "typecheck": "tsc -b",
    "test": "pnpm -r --parallel test --run",
    "codegen": "pnpm --filter @grackle/shared-types codegen",
    "check-parity": "node tools/check-parity.mjs",
    "prepare": "lefthook install && pnpm codegen"
  },
  "devDependencies": {
    "@biomejs/biome": "^2.5.2",
    "@commitlint/cli": "^21.2.0",
    "@commitlint/config-conventional": "^21.2.0",
    "concurrently": "^10.0.3",
    "json-schema-to-typescript": "^15.0.4",
    "lefthook": "^2.1.9",
    "typescript": "^6.0.3"
  }
}
