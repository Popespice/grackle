{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "adapters",
  "title": "grackle adapter contracts",
  "description": "Contracts for language adapter Protocols. See ADR-0003 (adapter design) and ADR-0004 (extension surface).",
  "$defs": {
    "Capabilities": {
      "type": "object",
      "description": "What an adapter promises to deliver. False means not yet implemented.",
      "properties": {
        "files": { "type": "boolean" },
        "classes": { "type": "boolean" },
        "functions": { "type": "boolean" },
        "imports": { "type": "boolean" },
        "calls": { "type": "boolean" },
        "runtime_tracing": { "type": "boolean" },
        "annotations": { "type": "boolean" }
      },
      "required": [
        "files",
        "classes",
        "functions",
        "imports",
        "calls",
        "runtime_tracing",
        "annotations"
      ],
      "additionalProperties": false
    },
    "ParseOptions": {
      "type": "object",
      "description": "Options passed to a static parser adapter.",
      "properties": {
        "exclude_patterns": {
          "type": "array",
          "items": { "type": "string" },
          "description": "Glob-style patterns for paths to exclude from analysis."
        },
        "include_external": {
          "type": "boolean",
          "description": "Whether to follow imports outside the project root."
        },
        "follow_imports": {
          "type": "boolean",
          "description": "Whether to resolve and follow import edges."
        }
      },
      "required": ["exclude_patterns", "include_external", "follow_imports"],
      "additionalProperties": false
    },
    "StaticGraph": {
      "type": "object",
      "description": "Static analysis graph artifact emitted by a StaticParserAdapter. See graph.schema.json#/$defs/Graph for the canonical, fully-typed top-level shape.",
      "properties": {
        "version": {
          "type": "integer",
          "description": "Schema version for forward-compatibility."
        },
        "language": {
          "type": "string",
          "description": "Open string — see ADR-0004. Known values listed in examples.",
          "examples": ["python", "typescript", "go", "rust"]
        },
        "nodes": {
          "type": "array",
          "description": "Graph nodes — see graph.schema.json#/$defs/GraphNode.",
          "items": { "$ref": "graph.schema.json#/$defs/GraphNode" }
        },
        "edges": {
          "type": "array",
          "description": "Graph edges — see graph.schema.json#/$defs/GraphEdge.",
          "items": { "$ref": "graph.schema.json#/$defs/GraphEdge" }
        }
      },
      "required": ["version", "language", "nodes", "edges"],
      "additionalProperties": false
    },
    "TraceEvent": {
      "type": "object",
      "description": "Phase-1 skeleton for a runtime trace event. Fleshed out in phase 6.",
      "properties": {
        "id": { "type": "string" },
        "timestamp": {
          "type": "number",
          "description": "Unix epoch seconds (float)."
        },
        "type": {
          "type": "string",
          "description": "Open string — see ADR-0004. Common values: 'call', 'return', 'exception'."
        },
        "payload": {
          "type": "object",
          "description": "Event-type-specific data.",
          "additionalProperties": {}
        }
      },
      "required": ["id", "timestamp", "type", "payload"],
      "additionalProperties": false
    }
  }
}
