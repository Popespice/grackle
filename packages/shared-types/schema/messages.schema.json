{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "messages",
  "title": "grackle WebSocket messages",
  "description": "Wire format for agent ↔ browser WebSocket communication. Unknown message types MUST be silently ignored by all consumers.",
  "$defs": {
    "WsEnvelope": {
      "type": "object",
      "description": "Base envelope — every wire message shares this shape.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Correlation ID, echoed verbatim in any reply."
        },
        "type": {
          "type": "string",
          "description": "Message discriminator. Open string — consumers MUST ignore unknown types."
        },
        "payload": {
          "type": "object",
          "description": "Message-specific data. Shape depends on type.",
          "additionalProperties": true
        }
      },
      "required": ["id", "type", "payload"],
      "additionalProperties": false
    },
    "PingMessage": {
      "description": "Heartbeat sent by the browser. Agent replies with PongMessage.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "ping" },
            "payload": { "type": "object", "maxProperties": 0 }
          },
          "required": ["type"]
        }
      ]
    },
    "PongMessage": {
      "description": "Heartbeat reply from the agent.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "pong" },
            "payload": {
              "type": "object",
              "properties": {
                "ping_id": {
                  "type": "string",
                  "description": "The id of the PingMessage this responds to."
                }
              },
              "required": ["ping_id"],
              "additionalProperties": false
            }
          },
          "required": ["type"]
        }
      ]
    },
    "StaticGraphMessage": {
      "description": "Unsolicited push from agent on connect — the full static analysis graph. Payload shape is graph.schema.json#/$defs/Graph.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "static_graph" },
            "payload": {
              "type": "object",
              "description": "A Graph — see graph.schema.json#/$defs/Graph.",
              "additionalProperties": true
            }
          },
          "required": ["type"]
        }
      ]
    },
    "ReadSourceRequest": {
      "description": "Browser requests raw source text for a file at a POSIX-relative path.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "read_source" },
            "payload": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string",
                  "description": "POSIX-relative path from project root. No backslashes.",
                  "pattern": "^[^\\\\]*$"
                }
              },
              "required": ["path"],
              "additionalProperties": false
            }
          },
          "required": ["type"]
        }
      ]
    },
    "ReadSourceResponse": {
      "description": "Agent reply with file content. id echoes the ReadSourceRequest id.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "source_response" },
            "payload": {
              "type": "object",
              "properties": {
                "path": { "type": "string" },
                "source": { "type": "string" },
                "encoding": { "type": "string" }
              },
              "required": ["path", "source", "encoding"],
              "additionalProperties": false
            }
          },
          "required": ["type"]
        }
      ]
    },
    "ReadSourceError": {
      "description": "Agent error reply when ReadSourceRequest cannot be fulfilled. id echoes the request.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "source_error" },
            "payload": {
              "type": "object",
              "properties": {
                "path": { "type": "string" },
                "reason": {
                  "type": "string",
                  "enum": ["not_found", "forbidden", "binary", "too_large"]
                }
              },
              "required": ["path", "reason"],
              "additionalProperties": false
            }
          },
          "required": ["type"]
        }
      ]
    },
    "AgentHelloMessage": {
      "description": "Demo-branch unsolicited push from agent on connect — fixture metadata + pulse settings. Not part of the production protocol; consumed only by the demo branch.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "agent_hello" },
            "payload": {
              "type": "object",
              "properties": {
                "fixtures": {
                  "type": "array",
                  "items": { "type": "object", "additionalProperties": true }
                },
                "active": { "type": "string" },
                "live": { "type": "boolean" },
                "pulseIntervalMs": { "type": "number" },
                "pulseNodesPerPulse": { "type": "number" }
              },
              "required": ["fixtures", "active", "live"],
              "additionalProperties": false
            }
          },
          "required": ["type"]
        }
      ]
    },
    "LoadFixtureMessage": {
      "description": "Demo-branch browser→agent request to switch active fixture.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "load_fixture" },
            "payload": {
              "type": "object",
              "properties": { "name": { "type": "string" } },
              "required": ["name"],
              "additionalProperties": false
            }
          },
          "required": ["type"]
        }
      ]
    },
    "PulseMessage": {
      "description": "Demo-branch agent→browser live-pulse highlight. Random subset of node ids per tick. Phase 6/7 will replace with real sys.monitoring trace events.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "pulse" },
            "payload": {
              "type": "object",
              "properties": {
                "nodes": { "type": "array", "items": { "type": "string" } }
              },
              "required": ["nodes"],
              "additionalProperties": false
            }
          },
          "required": ["type"]
        }
      ]
    },
    "SetPulseRateMessage": {
      "description": "Demo-branch browser→agent request to adjust pulse-loop frequency.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "set_pulse_rate" },
            "payload": {
              "type": "object",
              "properties": {
                "intervalMs": { "type": "number" },
                "nodesPerPulse": { "type": "number" }
              },
              "additionalProperties": false
            }
          },
          "required": ["type"]
        }
      ]
    }
  }
}
