{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "messages",
  "title": "grackle WebSocket messages",
  "description": "Wire format for agent ↔ browser WebSocket communication. Unknown message types MUST be silently ignored by all consumers.",
  "$defs": {
    "WsEnvelope": {
      "type": "object",
      "description": "Base envelope — every wire message shares this shape.",
      "properties": {
        "id": {
          "type": "string",
          "description": "Correlation ID, echoed verbatim in any reply."
        },
        "type": {
          "type": "string",
          "description": "Message discriminator. Open string — consumers MUST ignore unknown types."
        },
        "payload": {
          "type": "object",
          "description": "Message-specific data. Shape depends on type.",
          "additionalProperties": true
        }
      },
      "required": ["id", "type", "payload"],
      "additionalProperties": false
    },
    "PingMessage": {
      "description": "Heartbeat sent by the browser. Agent replies with PongMessage.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "ping" },
            "payload": { "type": "object", "maxProperties": 0 }
          },
          "required": ["type"]
        }
      ]
    },
    "PongMessage": {
      "description": "Heartbeat reply from the agent.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "pong" },
            "payload": {
              "type": "object",
              "properties": {
                "ping_id": {
                  "type": "string",
                  "description": "The id of the PingMessage this responds to."
                }
              },
              "required": ["ping_id"],
              "additionalProperties": false
            }
          },
          "required": ["type"]
        }
      ]
    },
    "StaticGraphMessage": {
      "description": "Unsolicited push from agent on connect — the full static analysis graph. Payload shape is graph.schema.json#/$defs/Graph.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "static_graph" },
            "payload": {
              "type": "object",
              "description": "A Graph — see graph.schema.json#/$defs/Graph.",
              "additionalProperties": true
            }
          },
          "required": ["type"]
        }
      ]
    },
    "ReadSourceRequest": {
      "description": "Browser requests raw source text for a file at a POSIX-relative path.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "read_source" },
            "payload": {
              "type": "object",
              "properties": {
                "path": {
                  "type": "string",
                  "description": "POSIX-relative path from project root. No backslashes.",
                  "pattern": "^[^\\\\]*$"
                }
              },
              "required": ["path"],
              "additionalProperties": false
            }
          },
          "required": ["type"]
        }
      ]
    },
    "ReadSourceResponse": {
      "description": "Agent reply with file content. id echoes the ReadSourceRequest id.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "source_response" },
            "payload": {
              "type": "object",
              "properties": {
                "path": { "type": "string" },
                "source": { "type": "string" },
                "encoding": { "type": "string" }
              },
              "required": ["path", "source", "encoding"],
              "additionalProperties": false
            }
          },
          "required": ["type"]
        }
      ]
    },
    "ReadSourceError": {
      "description": "Agent error reply when ReadSourceRequest cannot be fulfilled. id echoes the request.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "source_error" },
            "payload": {
              "type": "object",
              "properties": {
                "path": { "type": "string" },
                "reason": {
                  "type": "string",
                  "enum": ["not_found", "forbidden", "binary", "too_large"]
                }
              },
              "required": ["path", "reason"],
              "additionalProperties": false
            }
          },
          "required": ["type"]
        }
      ]
    },
    "TraceSessionStartMessage": {
      "description": "Agent push signalling the start of a trace session (file replay or live-attach).",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "trace_session_start" },
            "payload": {
              "type": "object",
              "properties": {
                "session_id": {
                  "type": "string",
                  "description": "UUID identifying this trace session."
                },
                "started_ns": {
                  "type": "integer",
                  "description": "Monotonic start timestamp in nanoseconds."
                },
                "source": {
                  "type": "string",
                  "enum": ["replay", "live"],
                  "description": "Whether events come from a file replay or a live-attach producer."
                },
                "seekable": {
                  "type": "boolean",
                  "description": "When true, the server supports trace_seek_request for this session. Omitted (false) for live/real-time sessions."
                }
              },
              "required": ["session_id", "started_ns", "source"],
              "additionalProperties": false
            }
          },
          "required": ["type"]
        }
      ]
    },
    "TraceEventMessage": {
      "description": "Single runtime trace event pushed during a trace session. Payload shape is trace.schema.json#/$defs/TraceEvent.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "trace_event" },
            "payload": {
              "type": "object",
              "description": "A TraceEvent — see trace.schema.json#/$defs/TraceEvent.",
              "additionalProperties": true
            }
          },
          "required": ["type"]
        }
      ]
    },
    "TraceSessionEndMessage": {
      "description": "Agent push signalling the end of a trace session.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "trace_session_end" },
            "payload": {
              "type": "object",
              "properties": {
                "session_id": {
                  "type": "string",
                  "description": "UUID matching the corresponding trace_session_start."
                },
                "ended_ns": {
                  "type": "integer",
                  "description": "Monotonic end timestamp in nanoseconds."
                },
                "event_count": {
                  "type": "integer",
                  "description": "Total number of trace_event messages sent in this session.",
                  "minimum": 0
                }
              },
              "required": ["session_id", "ended_ns", "event_count"],
              "additionalProperties": false
            }
          },
          "required": ["type"]
        }
      ]
    },
    "TraceSeekRequest": {
      "description": "Browser requests a window of events from a seekable trace session. Agent replies with TraceWindowMessage or TraceSeekError. id is echoed verbatim.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "trace_seek_request" },
            "payload": {
              "type": "object",
              "properties": {
                "session_id": {
                  "type": "string",
                  "description": "UUID of the seekable trace session."
                },
                "start_index": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Zero-based absolute index of the first event to return."
                },
                "count": {
                  "type": "integer",
                  "minimum": 1,
                  "description": "Maximum number of events to return."
                }
              },
              "required": ["session_id", "start_index", "count"],
              "additionalProperties": false
            }
          },
          "required": ["type"]
        }
      ]
    },
    "TraceWindowMessage": {
      "description": "Agent reply to TraceSeekRequest — a window of trace events. id echoes the request id.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "trace_window" },
            "payload": {
              "type": "object",
              "properties": {
                "session_id": {
                  "type": "string",
                  "description": "UUID of the trace session."
                },
                "start_index": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Absolute index of the first event in this window."
                },
                "events": {
                  "type": "array",
                  "items": {
                    "type": "object",
                    "description": "A TraceEvent — see trace.schema.json#/$defs/TraceEvent.",
                    "additionalProperties": true
                  },
                  "description": "The requested window of trace events."
                },
                "total": {
                  "type": "integer",
                  "minimum": 0,
                  "description": "Total number of events in the trace file (for scrubber sizing)."
                }
              },
              "required": ["session_id", "start_index", "events", "total"],
              "additionalProperties": false
            }
          },
          "required": ["type"]
        }
      ]
    },
    "TraceSeekError": {
      "description": "Agent error reply when TraceSeekRequest cannot be fulfilled. id echoes the request id.",
      "allOf": [
        { "$ref": "#/$defs/WsEnvelope" },
        {
          "properties": {
            "type": { "const": "trace_seek_error" },
            "payload": {
              "type": "object",
              "properties": {
                "session_id": {
                  "type": "string",
                  "description": "UUID from the failed request."
                },
                "reason": {
                  "type": "string",
                  "description": "Human-readable reason (open string — e.g. 'session not found', 'not seekable')."
                }
              },
              "required": ["session_id", "reason"],
              "additionalProperties": false
            }
          },
          "required": ["type"]
        }
      ]
    }
  }
}
